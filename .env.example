# NexusMatrix 环境配置

# ── OpenAI (必需，用于语义搜索 embedding) ──
OPENAI_API_KEY="sk-your-openai-api-key"

# ── NexusMatrix 服务配置 (可选，有默认值) ──
# NEXUS_HOST=0.0.0.0
# NEXUS_PORT=8900
# NEXUS_DEBUG=false
# NEXUS_LOG_LEVEL=INFO

# ── Matrix Homeserver 配置 ──
# NEXUS_MATRIX_HOMESERVER_URL=http://localhost:8008
# NEXUS_MATRIX_SERVER_NAME=localhost
# NEXUS_MATRIX_REGISTRATION_SECRET=nexus-shared-secret
# NEXUS_MATRIX_ADMIN_USER=nexus_admin
# NEXUS_MATRIX_ADMIN_PASSWORD=nexus_admin_pass_2026

# ── 数据库 ──
# NEXUS_DATABASE_PATH=data/nexus_matrix.db

# ── 安全 ──
# NEXUS_SECRET_KEY=nexus-matrix-secret-change-me-in-production
